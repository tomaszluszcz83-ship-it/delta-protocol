{
  "name": "@delta-protocol/typescript-verifier",
  "version": "2.9.3",
  "private": true,
  "type": "module",
  "description": "Experimental DELTA TypeScript verifier with .delta bundle verification",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "verify-vectors": "tsc -p tsconfig.json && node dist/scripts/verify-vectors.js ../../tests/vectors/canonical-json/vectors.json",
    "verify-record": "tsc -p tsconfig.json && node dist/scripts/verify-record.js",
    "verify-schemas": "tsc -p tsconfig.json && node dist/scripts/verify-schemas.js ../../schemas",
    "validate-schema": "tsc -p tsconfig.json && node dist/scripts/validate-schema.js",
    "create-signed-record-demo": "tsc -p tsconfig.json && node dist/scripts/create-signed-record-demo.js",
    "verify-signed-record": "tsc -p tsconfig.json && node dist/scripts/verify-signed-record.js",
    "verify-bundle": "tsc -p tsconfig.json && node dist/scripts/verify-bundle.js",
    "test": "npm run verify-vectors && npm run verify-schemas"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.19.19",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
