{
  "name": "@delta-protocol/typescript-verifier",
  "version": "2.12.1",
  "private": true,
  "type": "module",
  "description": "Experimental DELTA TypeScript verifier with detached intent signature verification",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "verify-vectors": "tsc -p tsconfig.json && node dist/scripts/verify-vectors.js ../../tests/vectors/canonical-json/vectors.json",
    "verify-record": "tsc -p tsconfig.json && node dist/scripts/verify-record.js",
    "verify-schemas": "tsc -p tsconfig.json && node dist/scripts/verify-schemas.js ../../schemas",
    "validate-schema": "tsc -p tsconfig.json && node dist/scripts/validate-schema.js",
    "create-signed-record-demo": "tsc -p tsconfig.json && node dist/scripts/create-signed-record-demo.js",
    "verify-signed-record": "tsc -p tsconfig.json && node dist/scripts/verify-signed-record.js",
    "verify-bundle": "tsc -p tsconfig.json && node dist/scripts/verify-bundle.js",
    "verify-signed-bundle": "tsc -p tsconfig.json && node dist/scripts/verify-signed-bundle.js",
    "verify-signed-record-json": "tsc -p tsconfig.json && node dist/scripts/verify-signed-record-json.js",
    "verify-bundle-json": "tsc -p tsconfig.json && node dist/scripts/verify-bundle-json.js",
    "verify-signed-bundle-json": "tsc -p tsconfig.json && node dist/scripts/verify-signed-bundle-json.js",
    "verify-intent": "tsc -p tsconfig.json && node dist/scripts/verify-intent.js",
    "verify-intent-json": "tsc -p tsconfig.json && node dist/scripts/verify-intent-json.js",
    "create-signed-intent-demo": "tsc -p tsconfig.json && node dist/scripts/create-signed-intent-demo.js",
    "test": "npm run verify-vectors && npm run verify-schemas"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
