# DELTA Protocol byte-stability policy.
# Verification hashes are computed over exact bytes.
# These rules prevent Windows CRLF checkout from breaking public proof hashes.

spec/** text eol=lf
docs/spec/** text eol=lf

*.py text eol=lf
README.md text eol=lf

docs/**/*.html text eol=lf
docs/**/*.css text eol=lf
docs/**/*.js text eol=lf
docs/**/*.md text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.zip binary